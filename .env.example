# SerpApi key (required). Get one at https://serpapi.com/manage-api-key
SERPAPI_API_KEY=

# Optional. Base URL of the LM Studio server (default: http://localhost:1234).
# LMSTUDIO_URL=http://localhost:1234

# Optional. Pin the model's context window in tokens (default: auto-size to your machine).
# LMSTUDIO_CONTEXT_LENGTH=8192

# Optional. Seconds an idle model stays loaded before it auto-unloads (default: 300).
# LMSTUDIO_TTL_SECONDS=300
